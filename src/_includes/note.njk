<!doctype html>
<html class="no-js" lang="">
    {% include "partials/_head.njk" %}
    <body>
    <div class="aurora">
    </div>
        {% include "partials/_navigation.njk" %}

        <div class="wrapper">
    		<main>
                <div>
                <div class="onepage--centered note">
                <h1>{{ title }}</h1>
                {{ content | safe }}
                </div>
                <section>
                    <div class="section-separator"></div>
                    <div>
                        <ul class="notesgrid  bottom-spacing--medium">
                            <li class="">
                                <a class="notesgrid__link" href="/notes">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="notesgrid__icon"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
                                    <div class="noteinformation">
                                        <span class="noteinformation__title">Notes Page</span>
                                        <span class="noteinformation__metadata smalltext">Explore other thoughts</span>
                                    </div>
                                </a>
                            </li>
                            {% set currentCategory = category %}
                            {% set displayCount = 0 %}
                            {% for note in collections.notes %}
                                {% if note.data.category == currentCategory and note.url != page.url %}
                                    {% if displayCount < 6 %}
                                        <li class="">
                                            <a class="notesgrid__link" href="{{ note.url }}">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="notesgrid__icon"><path d="M13.4 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7.4"/><path d="M2 6h4"/><path d="M2 10h4"/><path d="M2 14h4"/><path d="M2 18h4"/><path d="M18.4 2.6a2.17 2.17 0 0 1 3 3L16 11l-4 1 1-4Z"/></svg>
                                                <div class="noteinformation">
                                                    <span class="noteinformation__title">{{ note.data.title }}</span>
                                                    <span class="noteinformation__metadata smalltext">{{ note.data.category }} • {{ note.data.updated | readableDate }}</span>
                                                </div>
                                            </a>
                                        </li>
                                        {% set displayCount = displayCount + 1 %}
                                    {% endif %}
                                {% endif %}
                            {% endfor %}
                        </ul>
                    </div>
                    </div>
                </section>
            </main>
        </div>
            {% include "partials/_footer.njk" %}
    </body>
</html>