<!doctype html>
<html class="no-js" lang="">
    {% include "partials/_head.njk" %}
    <body>
            {% include "partials/_navigation.njk" %}
    		<main class="onepage--centered note">
                    <h1>{{ title }}</h1>
                    {{ content | safe }}
                    </div>
                    <div class="kudos">
                        <button class="tinylytics_kudos" data-path="{{ page.url }}">🤘 1</button><span>← anonymous kudos</span>
                    </div>
                    <div class="grid__notes notes-after-note">
                    {% if collections.notes.length > 0 %}
                    <ul>
                    {% for item in collections.notes %}
                            <li class="notes__item">
                                <a class="notes__content" href="{{ item.url }}">
                                    <span class="notes__heading">{{ item.data.title }}</span>
                                    <span style="margin-left: auto;" class="notes__category">{{ item.data.category }}</span>
                                </a>
                            </li>
                    {% endfor %}
                    </ul>
                    {% else %}
                        <div class="review__description">
                            <span class="description__title">Excuse me while I gather my content.</span>
                            <span class="description__author">This is only temporary.</span>
                        </div>
                    {% endif %}
                    </div>
            </main>
            {% include "partials/_footer.njk" %}

        {% if env === "development" %}
            <script>
                // quick local test
            document.addEventListener('DOMContentLoaded', function () {
                var button = document.querySelector('.tinylytics_kudos');

                button.addEventListener('click', function() {
                button.disabled = true;
                button.classList.add('did_select');
                button.innerHTML = "🤘 2"
                });
            });
            </script>
        {% endif %}

    </body>
</html>