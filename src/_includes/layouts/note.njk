<!doctype html>
<html class="no-js" lang="">
    {% include "partials/_head.njk" %}
    <body>
            {% include "partials/_navigation.njk" %}
    		<main class="onepage--centered note h-entry">
                    <h1 class="p-name">{{ title }}</h1>
                    <div class="e-content">
                        {{ content | safe }}
                    </div>
                    </div>
                    <div class="kudos">
                        {# <span class="tinylytics_kudos--emoji">🤘</span> #}
                        <button class="tinylytics_kudos" data-path="{{ page.url }}">1</button><span class="tinylytics_kudos--hint">← anonymous kudos for <a href="{{ page.url }}" class="u-url" title="Link to current page">permalink</span>
                    </div>
                    <div class="grid__notes notes-after-note">
                        {% if collections.notes.length > 0 %}
                            <ul>
                                {% for item in collections.notes %}
                                    {% if item.url != page.url %}
                                        <li class="notes__item">
                                            <a class="notes__content" href="{{ item.url }}">
                                                <span class="notes__heading">{{ item.data.title }}</span>
                                                <span style="margin-left: auto;" class="notes__category">{{ item.data.category }}</span>
                                            </a>
                                        </li>
                                    {% endif %}
                                {% endfor %}
                            </ul>
                        {% else %}
                            <div class="review__description">
                                <span class="description__title">Excuse me while I gather my content.</span>
                                <span class="description__author">This is only temporary.</span>
                            </div>
                        {% endif %}
                    </div>
                 {% include "partials/_authorinfo.njk" %}
            </main>
            {% include "partials/_footer.njk" %}

        {# if env === "development" %}
            <script>
                // quick local test
            document.addEventListener('DOMContentLoaded', function () {
                var button = document.querySelector('.tinylytics_kudos');

                button.addEventListener('click', function() {
                button.disabled = true;
                button.classList.add('did_select');
                button.innerHTML = "2"
                });
            });
            </script>
        {% endif #}
    </body>
</html>