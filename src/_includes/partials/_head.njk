vigation__item:not(:last-child){border-right:1px solid hsla(225,14%,57%,.2)}}@media screen and (max-width:767px){.navigation{display:block;position:sticky;z-index:4;scroll-behavior:smooth}.navigation__list{display:flex;padding:0;margin:.5rem}.navigation__link{padding:1rem;background:hsla(225,24%,97%,.97);border-top:1px solid hsla(225,14%,97%,.3);border-bottom:1px solid hsla(225,14%,97%,.3)}.navigation__item:first-child .navigation__link{border-radius:.75rem 0 0 .75rem;padding-left:1.5rem}.navigation__item:last-child .navigation__link{border-radius:0 .75rem .75rem 0;margin-right:16px;padding-right:1.5rem}}p:first-child{margin-top:0}.introduction{max-width:70ch;margin-bottom:4rem}.introduction__title h1{margin-top:0}.project{position:relative;display:block;padding:1.25rem;background:hsla(225,24%,99%,.4);border-radius:.75rem;box-shadow:rgba(81,88,108,.4) 0 8px 30px -20px;backdrop-filter:blur(5px);border:1px solid hsla(225,14%,97%,.3);color:inherit;text-decoration:none}.project:before{content:"";top:0;left:0;right:0;bottom:0;position:absolute;box-shadow:rgba(81,88,108,.4) 0 16px 30px -12px;opacity:0}.project__cover{display:block;border-radius:calc(1.25rem - var(--outer-radius));background-size:100%;background-position:center;background-repeat:no-repeat;width:100%;padding-top:74.95%}.homepage-notes__item {border: 1px solid transparent;}.homepage-notes__heading{transform: translateY(2px);}
